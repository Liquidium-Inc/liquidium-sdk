{
  "name": "@liquidium/client",
  "version": "0.1.0",
  "description": "The official client for the Liquidium protocol",
  "keywords": [
    "liquidium",
    "sdk",
    "defi",
    "icp",
    "lending"
  ],
  "homepage": "https://github.com/Liquidium-Inc/liquidium-sdk",
  "bugs": {
    "url": "https://github.com/Liquidium-Inc/liquidium-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Liquidium-Inc/liquidium-sdk.git",
    "directory": "packages/client"
  },
  "author": "Liquidium",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run build && pnpm run typecheck"
  },
  "dependencies": {
    "@dfinity/agent": "2.1.3",
    "@dfinity/candid": "2.1.3",
    "@dfinity/ledger-icrc": "2.1.3",
    "@dfinity/principal": "2.1.3",
    "@icp-sdk/core": "^5.2.0",
    "@noble/hashes": "^1.8.0",
    "viem": "^2.44.4"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
