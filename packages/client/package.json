{
  "name": "@liquidium/client",
  "version": "0.5.1",
  "description": "The official client for the Liquidium protocol",
  "keywords": [
    "liquidium",
    "sdk",
    "defi",
    "icp",
    "borrowing",
    "lending"
  ],
  "homepage": "https://liquidium-inc.github.io/liquidium-sdk/",
  "bugs": {
    "url": "https://github.com/Liquidium-Inc/liquidium-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Liquidium-Inc/liquidium-sdk.git",
    "directory": "packages/client"
  },
  "author": "Liquidium",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run build && pnpm run typecheck"
  },
  "dependencies": {
    "@dfinity/utils": "^4.2.1",
    "@icp-sdk/canisters": "^3.6.0",
    "@icp-sdk/core": "^5.4.0",
    "@scure/base": "^2.2.0",
    "bitcoin-address-validation": "^3.0.0",
    "viem": "^2.50.4"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
