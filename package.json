{
  "name": "liquidium-sdk",
  "version": "0.0.0",
  "description": "The official SDK for the Liquidium protocol",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo watch build",
    "clean": "rimraf packages/*/dist",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "docs:changelog": "node scripts/generate-docs-changelog.mjs",
    "docs:api": "typedoc",
    "test": "vitest run",
    "test:e2e": "LIQUIDIUM_LIVE_E2E=1 vitest run --project client-e2e",
    "typecheck": "turbo typecheck",
    "release:version": "pnpm changeset version && pnpm docs:changelog",
    "release": "pnpm run build && pnpm changeset publish"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.14",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.5.1"
}
